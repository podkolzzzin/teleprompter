{
  "name": "teleprompter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "mcp": "playwright-mcp --port 8931"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "mammoth": "^1.12.0",
    "marked": "^12.0.0",
    "pdfjs-dist": "^5.5.207",
    "peerjs": "^1.5.5",
    "qrcode": "^1.5.4",
    "turndown": "^7.2.2",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.58.2",
    "@types/qrcode": "^1.5.6",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.0.0"
  }
}
